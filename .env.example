# ============================================================================
# Honda Motos Dashboard — Variables de entorno
# Copia este archivo a .env y rellena con los valores reales.
# NUNCA commitees el .env real.
# ============================================================================

# --- Metrics DB (MySQL) ---
METRICS_HOST=
METRICS_USER=
METRICS_PASSWORD=
METRICS_DATABASE=metrics

# --- Sicofi DB (MySQL) ---
SICOFI_HOST=
SICOFI_USER=
SICOFI_PASSWORD=
SICOFI_DATABASE=sicofi

# --- Hmcrm DB (MySQL) ---
HMCRM_HOST=
HMCRM_USER=
HMCRM_PASSWORD=
HMCRM_DATABASE=hmcrm

# --- PostgreSQL DWH ---
PG_HOST=localhost
PG_USER=postgres
PG_PASSWORD=
PG_DATABASE=honda_motos
PG_PORT=5432

# --- ETL Config ---
SUCURSALES_PERMITIDAS=6,8
FECHA_INICIO=2024-01-01

# --- Backend FastAPI ---
# development | production — production activa rate-limit y oculta /docs
ENVIRONMENT=development
# CORS: lista de orígenes permitidos separados por coma (en prod, el dominio CF Pages)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
